{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "not_operator_with_successor_space": false,
        "phpdoc_align": {
            "align": "left"
        },
        "phpdoc_summary": false,
        "single_line_comment_style": {
            "comment_types": [
                "hash"
            ]
        },
        "type_declaration_spaces": true
    }
}
